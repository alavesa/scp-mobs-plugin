{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "scp173_cage",
        "model": {
          "type": "minecraft:model",
          "model": "scp:item/cage"
        }
      },
      {
        "when": "scp173_cage_full",
        "model": {
          "type": "minecraft:model",
          "model": "scp:item/cage_full"
        }
      },
      {
        "when": "scp173_cage3d",
        "model": {
          "type": "minecraft:model",
          "model": "scp:entity/scp173_cage3d"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/iron_bars"
    }
  }
}
